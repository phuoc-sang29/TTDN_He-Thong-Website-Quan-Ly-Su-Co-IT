# Sao chép file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git

PORT=3001

# Supabase — lấy từ: Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini — lấy từ: https://aistudio.google.com/app/apikey
# Nhiều key cách nhau bằng dấu phẩy (tự động xoay vòng khi hết quota)
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
